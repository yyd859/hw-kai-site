{
  "id": "mpu6050",
  "label": "MPU6050 6轴 IMU",
  "category": "input",
  "subcategory": "sensor",
  "description": "InvenSense MPU6050，3轴陀螺仪+3轴加速度，I2C，最常用的 IMU 模块",
  "provides": [
    "gyroscope",
    "accelerometer",
    "imu",
    "tilt_sensing",
    "motion_detection"
  ],
  "interface": "i2c",
  "pin_spec": {
    "VCC": {
      "type": "power_in",
      "voltage": "3.3-5V",
      "note": "电源（模块已稳压）"
    },
    "SDA": {
      "type": "i2c_data",
      "voltage": "3.3V",
      "note": "I2C 数据"
    },
    "SCL": {
      "type": "i2c_clk",
      "voltage": "3.3V",
      "note": "I2C 时钟"
    },
    "AD0": {
      "type": "io",
      "voltage": "3.3V",
      "note": "地址选择：低=0x68，高=0x69"
    },
    "INT": {
      "type": "digital_out",
      "voltage": "3.3V",
      "note": "数据就绪中断"
    },
    "GND": {
      "type": "gnd",
      "voltage": "0V",
      "note": "地"
    }
  },
  "compatible_boards": [
    "esp32_devkit_v1",
    "arduino_uno_r3"
  ],
  "library_required": "MPU6050 by Electronic Cats / Adafruit MPU6050",
  "specs": {
    "gyro_range": "±250/500/1000/2000°/s",
    "accel_range": "±2/4/8/16g",
    "i2c_addr": "0x68/0x69"
  },
  "notes": [
    "内置 DMP（数字运动处理器）可直接输出四元数",
    "需要校准零偏，否则静止时有漂移"
  ],
  "price_cny": {
    "min": 3,
    "max": 10,
    "typical": 5
  }
}