{
  "id": "arduino_nano",
  "label": "Arduino Nano",
  "category": "board",
  "subcategory": "microcontroller",
  "description": "Arduino Nano，ATmega328P，比 Uno 更小巧，适合面包板使用",
  "provides": [
    "gpio",
    "i2c",
    "spi",
    "uart",
    "pwm",
    "adc"
  ],
  "interface": "usb",
  "pin_spec": {
    "5V": {
      "type": "power_out",
      "voltage": "5V",
      "note": "5V 电源"
    },
    "3V3": {
      "type": "power_out",
      "voltage": "3.3V",
      "note": "3.3V 输出"
    },
    "GND": {
      "type": "gnd",
      "voltage": "0V",
      "note": "地"
    },
    "VIN": {
      "type": "power_in",
      "voltage": "7-12V",
      "note": "外部电源"
    },
    "A0-A7": {
      "type": "analog_in",
      "voltage": "0-5V",
      "note": "8路模拟输入（A6/A7 只能模拟）"
    },
    "D2": {
      "type": "io",
      "voltage": "5V",
      "note": "外部中断 INT0"
    }
  },
  "compatible_boards": [],
  "library_required": "内置",
  "specs": {
    "cpu": "ATmega328P 16MHz",
    "flash": "32KB",
    "ram": "2KB",
    "gpio": 22,
    "adc": "8ch 10bit"
  },
  "notes": [
    "A6/A7 为只读模拟引脚，不能做数字 IO",
    "USB 接口旧版为 Mini-USB，新版为 Type-C"
  ],
  "price_cny": {
    "min": 5,
    "max": 20,
    "typical": 10
  }
}